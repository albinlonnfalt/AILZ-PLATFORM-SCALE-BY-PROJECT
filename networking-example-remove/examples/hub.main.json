{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "baseName": {
      "value": "hub"
    },
    "location": {
      "value": "swedencentral"
    },
    "tags": {
      "value": {
        "workload": "hub-network",
        "role": "hub-network"
      }
    },
    "hubVnetAddressPrefixes": {
      "value": [
        "10.0.0.0/16"
      ]
