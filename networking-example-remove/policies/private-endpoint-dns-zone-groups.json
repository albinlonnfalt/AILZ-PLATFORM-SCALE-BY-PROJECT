        "policyDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/policyDefinitions', parameters('policyDefinitionName'))]",
        "enforcementMode": "Default",
        "parameters": {
          "effect": {
            "value": "DeployIfNotExists"
          },
          "groupIds": {
            "value": "[variables('dnsMappings')[copyIndex()].groupIds]"
          },
          "privateDnsZoneIds": {
            "value": "[map(variables('dnsMappings')[copyIndex()].privateDnsZoneConfigs, lambda('config', lambdaVariables('config').privateDnsZoneId))]"
          },
          "privateDnsZoneConfigs": {
            "value": "[variables('dnsMappings')[copyIndex()].privateDnsZoneConfigs]"
          },
          "dnsZoneGroupName": {
            "value": "[parameters('dnsZoneGroupName')]"
          }
        }
      },
