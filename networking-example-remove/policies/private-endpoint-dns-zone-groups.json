  },
  "resources": {
    "privateEndpointDnsPolicy": {
      "type": "Microsoft.Authorization/policyDefinitions",
      "apiVersion": "2023-04-01",
      "name": "[parameters('policyDefinitionName')]",
      "properties": {
        "displayName": "Deploy private DNS zone groups for private endpoints",
        "description": "Automatically creates private DNS zone groups on private endpoints so their A-records are registered in the configured Private DNS zones.",
        "policyType": "Custom",
        "mode": "Indexed",
        "metadata": {
          "category": "Network",
          "version": "1.0.0"
        },
        "parameters": {
          "effect": {
            "type": "String",
            "metadata": {
              "displayName": "Effect",
              "description": "Enable or disable private DNS zone group deployment."
            },
            "allowedValues": [
              "DeployIfNotExists",
              "Disabled"
            ],
            "defaultValue": "DeployIfNotExists"
          },
          "groupIds": {
            "type": "Array",
            "metadata": {
              "displayName": "Private endpoint group IDs",
              "description": "Private endpoint group IDs that should receive this DNS zone group."
            }
          },
          "privateDnsZoneIds": {
            "type": "Array",
            "metadata": {
              "displayName": "Private DNS zone IDs",
              "description": "Private DNS zone resource IDs that must exist in the DNS zone group."
            }
          },
          "privateDnsZoneConfigs": {
            "type": "Array",
            "metadata": {
              "displayName": "Private DNS zone configs",
              "description": "Private DNS zone group configuration objects containing name and privateDnsZoneId."
            }
          },
          "dnsZoneGroupName": {
            "type": "String",
            "metadata": {
              "displayName": "DNS zone group name",
              "description": "Name of the private DNS zone group to deploy on matching private endpoints."
            },
            "defaultValue": "default"
          }
        },
        "policyRule": {
          "if": {
            "allOf": [
              {
                "field": "type",
                "equals": "Microsoft.Network/privateEndpoints"
              },
              {
                "anyOf": [
                  {
                    "count": {
                      "field": "Microsoft.Network/privateEndpoints/privateLinkServiceConnections[*].groupIds[*]",
                      "where": {
                        "field": "Microsoft.Network/privateEndpoints/privateLinkServiceConnections[*].groupIds[*]",
                        "in": "[[parameters('groupIds')]"
                      }
                    },
                    "greater": 0
                  },
                  {
                    "count": {
                      "field": "Microsoft.Network/privateEndpoints/manualPrivateLinkServiceConnections[*].groupIds[*]",
                      "where": {
                        "field": "Microsoft.Network/privateEndpoints/manualPrivateLinkServiceConnections[*].groupIds[*]",
                        "in": "[[parameters('groupIds')]"
                      }
                    },
                    "greater": 0
                  }
                ]
              }
            ]
          },
          "then": {
            "effect": "[[parameters('effect')]",
            "details": {
              "type": "Microsoft.Network/privateEndpoints/privateDnsZoneGroups",
              "roleDefinitionIds": [
                "[variables('networkContributorRoleDefinitionId')]",
                "[variables('privateDnsZoneContributorRoleDefinitionId')]"
              ],
              "existenceCondition": {
                "count": {
                  "field": "Microsoft.Network/privateEndpoints/privateDnsZoneGroups/privateDnsZoneConfigs[*].privateDnsZoneId",
                  "where": {
                    "field": "Microsoft.Network/privateEndpoints/privateDnsZoneGroups/privateDnsZoneConfigs[*].privateDnsZoneId",
                    "in": "[[parameters('privateDnsZoneIds')]"
                  }
                },
                "equals": "[[length(parameters('privateDnsZoneIds'))]"
              },
              "deployment": {
                "properties": {
                  "mode": "incremental",
                  "template": {
                    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
                    "contentVersion": "1.0.0.0",
                    "parameters": {
                      "privateEndpointName": {
                        "type": "string"
                      },
                      "dnsZoneGroupName": {
                        "type": "string"
                      },
                      "privateDnsZoneConfigs": {
                        "type": "array"
                      }
                    },
                    "resources": [
                      {
                        "type": "Microsoft.Network/privateEndpoints/privateDnsZoneGroups",
                        "apiVersion": "2024-05-01",
                        "name": "[[concat(parameters('privateEndpointName'), '/', parameters('dnsZoneGroupName'))]",
                        "properties": {
                          "privateDnsZoneConfigs": "[[map(parameters('privateDnsZoneConfigs'), lambda('config', createObject('name', lambdaVariables('config').name, 'properties', createObject('privateDnsZoneId', lambdaVariables('config').privateDnsZoneId))))]"
                        }
                      }
                    ]
                  },
                  "parameters": {
                    "privateEndpointName": {
                      "value": "[[field('name')]"
                    },
                    "dnsZoneGroupName": {
                      "value": "[[parameters('dnsZoneGroupName')]"
                    },
                    "privateDnsZoneConfigs": {
                      "value": "[[parameters('privateDnsZoneConfigs')]"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "privateEndpointDnsAssignments": {
