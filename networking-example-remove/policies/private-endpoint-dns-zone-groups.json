                "name": "value",
                "count": "[length(variables('dnsMappings'))]",
                "input": "[format('{0}-{1}', parameters('policyAssignmentNamePrefix'), variables('dnsMappings')[copyIndex('value')].key)]"
              }
            ]
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "languageVersion": "2.0",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.41.2.15936",
              "templateHash": "5289831062954019289"
            }
          },
          "parameters": {
            "principalIds": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "metadata": {
                "description": "Managed identity principal IDs that need Private DNS Zone Contributor on this resource group."
              }
            },
            "roleAssignmentNameSeeds": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "metadata": {
                "description": "Deterministic seeds used for role assignment names. Must align with principalIds."
              }
            }
          },
          "variables": {
            "privateDnsZoneContributorRoleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'b12aa53e-6015-4669-85d0-8515ebb3ae7f')]"
          },
          "resources": {
            "privateDnsZoneContributor": {
              "copy": {
                "name": "privateDnsZoneContributor",
                "count": "[length(parameters('principalIds'))]"
              },
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "name": "[guid(resourceGroup().id, parameters('roleAssignmentNameSeeds')[copyIndex()], variables('privateDnsZoneContributorRoleDefinitionId'))]",
              "properties": {
