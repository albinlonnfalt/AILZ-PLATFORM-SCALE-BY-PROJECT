      "apiVersion": "2022-04-01",
      "name": "[guid(subscription().id, take(format('{0}-{1}', parameters('policyAssignmentNamePrefix'), variables('dnsMappings')[copyIndex()].key), 64), variables('networkContributorRoleDefinitionId'))]",
      "properties": {
        "roleDefinitionId": "[variables('networkContributorRoleDefinitionId')]",
        "principalId": "[reference(format('privateEndpointDnsAssignments[{0}]', copyIndex()), '2024-04-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[format('privateEndpointDnsAssignments[{0}]', copyIndex())]",
        "[format('privateEndpointDnsAssignments[{0}]', copyIndex())]"
      ]
    },
