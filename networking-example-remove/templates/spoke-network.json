              "type": "Microsoft.Network/privateDnsZones/virtualNetworkLinks",
              "apiVersion": "2024-06-01",
              "name": "[format('{0}/{1}', last(split(parameters('privateDnsZoneIds').appConfig, '/')), format('link-{0}', parameters('spokeVnetName')))]",
              "location": "global",
              "properties": {
                "registrationEnabled": "[parameters('registrationEnabled')]",
                "virtualNetwork": {
                  "id": "[parameters('spokeVnetId')]"
                }
              }
            },
            "containerAppsLink": {
              "condition": "[not(empty(parameters('privateDnsZoneIds').containerApps))]",
              "type": "Microsoft.Network/privateDnsZones/virtualNetworkLinks",
              "apiVersion": "2024-06-01",
              "name": "[format('{0}/{1}', last(split(parameters('privateDnsZoneIds').containerApps, '/')), format('link-{0}', parameters('spokeVnetName')))]",
              "location": "global",
              "properties": {
                "registrationEnabled": "[parameters('registrationEnabled')]",
                "virtualNetwork": {
                  "id": "[parameters('spokeVnetId')]"
                }
              }
            }
          },
          "outputs": {
            "linkedPrivateDnsZoneCount": {
              "type": "int",
              "value": "[length(filter(createArray(parameters('privateDnsZoneIds').cognitiveServices, parameters('privateDnsZoneIds').openAi, parameters('privateDnsZoneIds').aiServices, parameters('privateDnsZoneIds').blob, parameters('privateDnsZoneIds').file, parameters('privateDnsZoneIds').cosmos, parameters('privateDnsZoneIds').search, parameters('privateDnsZoneIds').keyVault, parameters('privateDnsZoneIds').acr, parameters('privateDnsZoneIds').appConfig, parameters('privateDnsZoneIds').containerApps), lambda('zoneId', not(empty(lambdaVariables('zoneId'))))))]"
            }
          }
        }
      },
      "dependsOn": [
        "spokeVnet"
      ]
    }
  },
  "outputs": {
    "spokeVnetId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/virtualNetworks', variables('spokeVnetName'))]"
    },
    "spokeVnetName": {
