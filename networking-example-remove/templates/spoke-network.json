    "containerAppsSubnetId": {
      "type": "string",
      "value": "[if(parameters('deployContainerAppsSubnet'), format('{0}/subnets/{1}', resourceId('Microsoft.Network/virtualNetworks', variables('spokeVnetName')), variables('containerAppsSubnetName')), '')]"
